generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- Auth (better-auth) ----------

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Rol dentro del modelo tutor-first: "guardian" (adulto que se registra y
  // da de alta menores) | "child" (menor creado por su tutor/a).
  role          String    @default("guardian")
  // Solo el AÑO de nacimiento (minimización de datos, Ley 25.326): nunca la
  // fecha completa. Se usa para franja etaria, no para identificar.
  birthYear     Int?
  // null = todavía no respondió; true/false orienta el onboarding sin guardar
  // detalles clínicos ni el nombre del diagnóstico.
  hasDiagnosis  Boolean?

  sessions      Session[]
  accounts      Account[]
  conversations Conversation[]
  memories      UserMemory[]
  safetyEvents  SafetyEvent[]
  interactionLogs InteractionLog[]
  moods         MoodEntry[]
  guardianFollowups GuardianFollowup[] @relation("gfGuardian")
  childFollowups    GuardianFollowup[] @relation("gfChild")
  tramiteProgress   TramiteProgress[]

  // Menores a cargo de este usuario (si es tutor/a).
  guardianOf    Guardian[] @relation("guardianOf")
  // Vínculo de tutela de este usuario (si es menor). Único: un menor tiene un
  // solo tutor/a por ahora.
  guardedBy     Guardian?  @relation("guardedBy")

  // Barrido de menores huérfanos (retention.orphanChildWhere): filtra por
  // role="child" + updatedAt < corte de gracia. Sin este índice el deleteMany del
  // cron es un full-table-scan de `user`. (`guardedBy` es una relación, no una
  // columna, así que no entra en el índice; el filtro por role+updatedAt es el que
  // acota el barrido.)
  @@index([role, updatedAt])
  @@map("user")
}

// ---------- Tutela y consentimiento (Ley 25.326) ----------

// Vincula un tutor/a (guardianUserId) con un menor (childUserId), ambos filas
// de `User`. Registra el consentimiento verificable exigido antes de que el
// menor pueda usar el chat: timestamp + IP + user-agent como evidencia.
model Guardian {
  id               String    @id @default(cuid())
  guardianUserId   String
  guardianUser     User      @relation("guardianOf", fields: [guardianUserId], references: [id], onDelete: Cascade)
  // Un menor tiene un único tutor/a por ahora.
  childUserId      String    @unique
  childUser        User      @relation("guardedBy", fields: [childUserId], references: [id], onDelete: Cascade)
  // Consentimiento: null hasta que el tutor/a lo otorga explícitamente.
  consentAt        DateTime?
  consentIp        String?
  consentUserAgent String?
  // Revocación de consentimiento (Ley 25.326, derecho de oposición): el tutor/a
  // puede SUSPENDER el acceso del menor sin borrar sus datos. null = consentimiento
  // vigente; no-null = suspendido desde ese instante. `canChat` trata un consent
  // revocado como no-consent (bloquea el chat). Reanudar = volver a null.
  consentRevokedAt DateTime?
  // Alertas de crisis al tutor/a (M-P2). Activadas por defecto.
  alertsEnabled    Boolean   @default(true)
  // Zona de la familia (Fase "Cerca tuyo"): filtra el directorio de recursos
  // reales y, a futuro, el enriquecimiento local de las plantillas de crisis.
  // Minimización: NO es domicilio (no es PII sensible), solo provincia/localidad.
  province         String?   // "neuquen" | "rionegro" | "nacional" | ...
  localidad        String?
  createdAt        DateTime  @default(now())

  @@index([guardianUserId])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Purga TTL (retention.purgeExpiredData): deleteMany por `expiresAt < now`.
  // Sin este índice el barrido es un full-table-scan de sesiones.
  @@index([expiresAt])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

// ---------- Chat ----------

model Conversation {
  id        String    @id @default(cuid())
  title     String    @default("Nueva conversación")
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
  // Capa 2 de memoria (research-architecture §4.1): resumen ≤120 palabras en
  // tercera persona, SIN datos identificables. Se genera lazy (lib/ai/memory)
  // cuando la conversación quedó "cerrada" (>1h sin actividad).
  summary      String?
  // Marca de procesamiento: no-null = ya pasó por summarizeStaleConversation
  // (aunque haya quedado sin summary por ser muy corta o por parse fallido).
  summarizedAt DateTime?
  // Capa de contexto activo (B2): resumen incremental de ESTA conversación en
  // curso (distinto de `summary`, que marca una conversación cerrada). Se
  // regenera lazy vía updateRollingSummary cuando el hilo se hace largo, para no
  // enviar todo el historial al modelo. SIN datos identificables (mismas reglas
  // anti-PII que el summary). `rollingSummarizedUntil` marca hasta qué momento
  // ya está cubierto por el resumen (los mensajes posteriores son incrementales).
  rollingSummary         String?
  rollingSummarizedUntil DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  interactionLogs InteractionLog[]

  @@index([userId, updatedAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String // "user" | "assistant"
  content        String
  // Marcado por la capa de seguridad (ej: "crisis", "derivacion")
  safetyFlag     String?
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
  // M-S7: la ventana de sesión (sessionWindowQuery) es un JOIN Message→Conversation
  // filtrando `Conversation.userId = ?` AND `Message.createdAt >= now-75min`.
  // Message NO tiene columna userId (vive en Conversation), así que no hay un
  // índice compuesto [userId, createdAt] posible sin DENORMALIZAR userId a Message
  // — algo que se evita a propósito (una fuente de verdad para el dueño del hilo).
  // Dado eso, el planner tiene dos caminos: (a) range-scan de este índice por la
  // franja de 75min y luego semi-join contra las conversaciones del usuario, o
  // (b) resolver primero las conversaciones del usuario y usar [conversationId,
  // createdAt]. La franja temporal es chica (75min de tráfico), así que ambos son
  // baratos; este índice acota el lado de Message por tiempo y evita el seq scan
  // del historial completo. Sin denormalización, no hay un índice estrictamente
  // mejor, por eso se deja como está.
  @@index([createdAt])
}

// ---------- Eventos de seguridad (anonimizados) ----------

// Registro anonimizado de cada activación de las capas de seguridad. NO guarda
// el contenido del mensaje: solo la categoría y en qué capa se disparó. Sirve
// para auditoría y, en una fase posterior, para alertar a un tutor (notifiedAt).
model SafetyEvent {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversationId String?
  // Valor del SafetyFlag ("crisis"|"abuso"|"riesgo"|"alimentario") o la
  // topCategory devuelta por la Moderation API.
  category       String
  // "keyword" | "moderation-input" | "moderation-output"
  layer          String
  createdAt      DateTime  @default(now())
  // Se completa cuando se avisó a un tutor (alertas — fase posterior).
  notifiedAt     DateTime?
  // Ciclo 15 L2b: se completa cuando el ENVÍO de la alerta de crisis falló tras
  // los reintentos (registro persistente del fallo en una ruta de seguridad). El
  // cron de purga lo reintenta (retryFailedCrisisAlerts); al enviarse con éxito se
  // marca notifiedAt y se limpia este campo. La purga NO lo borra por TTL (solo el
  // cascade al eliminar al menor); así un fallo pendiente no se pierde.
  alertFailedAt  DateTime?

  // Ruta del tutor/a (guardian/children/[childId]/safety-events): pagina por
  // { userId } ordenando por createdAt desc — cubierto por este índice.
  @@index([userId, createdAt])
  // Alertas de patrón (lib/alerts.ts): count/findFirst por { userId, category,
  // createdAt >= ventana }. Con solo [userId, createdAt] el filtro por category
  // se resolvía como scan+filter sobre la franja del usuario; este índice
  // compuesto lo cubre entero (equality userId+category, range createdAt).
  @@index([userId, category, createdAt])
}

// ---------- Base de conocimiento (RAG liviano) ----------

model KnowledgeCard {
  id        String   @id @default(cuid())
  slug      String   @unique
  category  String // neuro | intel | motora | sensorial | pocofrec | tramites
  title     String
  body      String // contenido en texto plano/markdown
  source    String? // ley / organismo que respalda
  reviewed  Boolean  @default(false) // true cuando un profesional la validó
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

// ---------- Directorio de recursos reales ("Cerca tuyo") ----------

// Recursos de ayuda REALES y georreferenciables: líneas nacionales, hospitales,
// CeSAC, ONGs, juntas evaluadoras, etc. NO son datos sensibles (directorio
// público); su valor es decir "a dónde ir ACÁ" cuando el sistema está saturado.
// Solo entran al producto los `reviewed: true` (validación humana del dato).
model HelpResource {
  id            String   @id @default(cuid())
  slug          String   @unique // clave estable para seed idempotente
  name          String
  // "crisis" | "salud_mental" | "discapacidad" | "escuela" | "linea" | "ong"
  kind          String
  // "nacional" | "neuquen" | "rionegro" | ...
  province      String
  localidad     String?
  address       String?
  lat           Float?
  lng           Float?
  phone         String?
  whatsapp      String?
  hours         String?  // "Lun a Vie 8–20", "24 hs"
  cost          String   @default("gratis") // "gratis" | "obra_social" | "arancel"
  takesChildren Boolean  @default(true)
  noAppointment Boolean  @default(false) // atiende sin turno / guardia
  url           String?
  notes         String?
  source        String?  // organismo que respalda el dato
  reviewed      Boolean  @default(false) // validado por una persona
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([province, kind])
}

// ---------- Trámites guiados ("Mis trámites") ----------

// Guía de un trámite (CUD, pensión, transporte, escolaridad, salud). Contenido
// versionable y validable por profesional (reviewed). `requirements` y `steps`
// son JSON tipados en lib/tramites.ts. Orientativo: siempre remite a la fuente
// oficial (sourceUrl). No es asesoramiento legal.
model TramiteGuide {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  summary       String
  // "cud" | "pension" | "transporte" | "escolaridad" | "salud"
  category      String
  estimatedTime String?
  requirements  Json // TramiteRequirement[]
  steps         Json // TramiteStep[]
  source        String?
  sourceUrl     String?
  reviewed      Boolean  @default(false)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([category])
}

// Progreso de UNA familia (tutor/a) en un trámite. Lo que vuelve "asistente" a
// las fichas: recuerda el paso y los documentos ya reunidos. Cascade con el tutor.
model TramiteProgress {
  id             String   @id @default(cuid())
  guardianUserId String
  guardianUser   User     @relation(fields: [guardianUserId], references: [id], onDelete: Cascade)
  guideSlug      String
  status         String   @default("in_progress") // in_progress | done | dismissed
  currentStep    Int      @default(0)
  checkedItems   Json     @default("[]") // índices de requisitos tildados
  startedAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([guardianUserId, guideSlug])
  @@index([guardianUserId])
}

// ---------- Puente: seguimiento de derivación del tutor/a ----------

// Registra la RESPUESTA del tutor/a a una situación detectada por Simón (los
// SafetyEvent, que ya existen). La "sugerencia" se COMPUTA de los SafetyEvent
// (nunca se guarda contenido del menor); esta tabla solo guarda qué hizo el
// tutor/a: contactó un recurso, lo resolvió o lo descartó. Un followup activo por
// par (tutor, menor). Cascade con ambos (baja de cuenta / barrido de huérfanos).
model GuardianFollowup {
  id             String   @id @default(cuid())
  guardianUserId String
  guardianUser   User     @relation("gfGuardian", fields: [guardianUserId], references: [id], onDelete: Cascade)
  childUserId    String
  childUser      User     @relation("gfChild", fields: [childUserId], references: [id], onDelete: Cascade)
  // Motivo agregado: "crisis" | "abuso" | "riesgo" | "alimentario".
  reason         String
  // "contacted" | "resolved" | "dismissed" ("suggested" es computado, no se guarda).
  status         String   @default("contacted")
  resourceId     String?
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([guardianUserId, childUserId])
  @@index([guardianUserId, status])
}

// ---------- Diario emocional del menor ("Mi diario") ----------

// Registro de ánimo (check-in de valencia 1–3) del menor. Parte de SU registro,
// no telemetría: SIN TTL propio (como Message/Conversation, ver retention.ts) —
// se purga solo por el cascade de User (baja de cuenta o barrido de huérfanos).
// value: 1 = mal · 2 = más o menos · 3 = bien. context: cómo se registró.
model MoodEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  value     Int
  context   String // "session_start" | "session_close" | "manual"
  note      String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// ---------- Memoria por usuario (aprendizaje) ----------

model UserMemory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      String // "fact" | "preference" | "context"
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  // Purga TTL (retention.purgeExpiredData): deleteMany por `updatedAt < corte 90d`.
  // Sin este índice el barrido es un full-table-scan de UserMemory.
  @@index([updatedAt])
  // Idempotencia del summarizer (memory.ts): dos invocaciones concurrentes de
  // summarizeStaleConversation (sin lock, marcan summarizedAt al final) pueden
  // extraer y guardar el MISMO hecho dos veces. Este unique + `skipDuplicates`
  // en el createMany hace que la segunda inserción sea un no-op en vez de un
  // duplicado. `content` está acotado en el parseo (MAX_FACT_CHARS, ~atómico y
  // corto) para no exceder el límite de fila del índice btree de Postgres, así
  // el unique va directo sobre el texto sin necesidad de una columna hash.
  @@unique([userId, kind, content])
}

// ---------- Telemetría de interacción (dataset de entrenamiento) ----------

// UN registro por request de chat que llega a producir una respuesta (TODOS los
// paths, incluidos los que no llaman al LLM: crisis, límite de sesión, fallback).
// Sirve para (a) observabilidad de performance/moderación y (b) construir el
// dataset de fine-tuning con export-training.
//
// CAMINO CRÍTICO (Ley 25.326, minimización — datos de menores): NUNCA guarda el
// contenido de los mensajes ni texto de moderación. Solo REFERENCIAS (ids),
// métricas de performance, y para moderación: fuente + flag + categoría. El
// registro es fire-and-forget vía after(): un fallo acá jamás rompe el chat (M1).
// TTL 180 días (purga lazy en el query-path del chat, junto con UserMemory).
model InteractionLog {
  id             String   @id @default(cuid())
  // FK cascade: si se borra el menor o la conversación, su telemetría se borra.
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  // Referencias sueltas (SIN FK): pueden apuntar a mensajes/eventos que un
  // borrado parcial haya eliminado; se aceptan colgadas (no bloquean el insert).
  userMessageId      String?
  assistantMessageId String?
  safetyEventId      String?

  // --- Performance ---
  model             String?
  totalLatencyMs    Int
  generationLatencyMs Int?
  inputTokens       Int?
  outputTokens      Int?
  totalTokens       Int?
  reasoningTokens   Int?
  cacheReadTokens   Int?

  // --- Moderación (fuente + flag + categoría, JAMÁS el texto) ---
  moderationInputSource   String?
  moderationInputFlagged  Boolean?
  moderationInputCategory String?
  moderationOutputSource   String?
  moderationOutputFlagged  Boolean?
  moderationOutputCategory String?

  // --- Resultado ---
  // "normal" | "crisis-template" | "moderation-replaced-output" |
  // "session-limit" | "no-ai" | "fallback-error" | "moderation-unavailable"
  responsePath       String
  safetyFlagFinal    String?
  historyMessagesSent Int
  // "guardian" | "child" — segmenta el dataset por tipo de interlocutor.
  roleAtRequest      String

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([conversationId])
  @@index([responsePath])
  // Purga TTL (retention.purgeExpiredData): deleteMany por `createdAt < corte 180d`.
  // Sin este índice el barrido es un full-table-scan de InteractionLog.
  @@index([createdAt])
}

// ADR-6 (enmienda): rate limiting de better-auth compartido vía Postgres
// (`rateLimit.storage: "database"`) cuando NO hay Upstash configurado. Una
// fila por clave (ip/path); el consumo es un UPDATE atómico condicional
// (`incrementOne` del prisma-adapter 1.6), sin ventana de carrera entre
// instancias. `lastRequest` es epoch ms → BigInt; better-auth lo normaliza a
// Number al leer. El nombre de tabla "rateLimit" es el que better-auth 1.6
// tiene hardcodeado para este storage.
model RateLimit {
  id          String @id @default(cuid())
  key         String @unique
  count       Int
  lastRequest BigInt

  // Poda que hace el propio better-auth en background tras cada ventana
  // vencida: deleteMany por `lastRequest < corte`. Sin índice = full scan.
  @@index([lastRequest])
  @@map("rateLimit")
}
