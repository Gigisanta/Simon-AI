# --- Base de datos ---
# SQLite local para desarrollo. En producción se puede apuntar a Postgres
# cambiando el provider del schema y esta URL.
DATABASE_URL="file:./prisma/dev.db"

# --- Auth (better-auth) ---
# Generar con: openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# --- Email transaccional (verificación del tutor/a) ---
# El tutor/a debe verificar su email antes de dar de alta a un menor.
# Si RESEND_API_KEY está seteada, se envía el email con Resend. Si NO está,
# la app loguea el link de verificación por consola (fallback de desarrollo:
# no rompe el registro local). Los menores usan email sintético .invalid y
# NUNCA reciben email. Ver docs/research-guardian.md §3.
# RESEND_API_KEY=""
# EMAIL_FROM="Simón <onboarding@resend.dev>"

# --- Proveedor de IA (intercambiable) ---
# Cualquier endpoint compatible con la API de OpenAI funciona:
#   DeepSeek:    https://api.deepseek.com        (AI_MODEL=deepseek-v4-flash)
#   OpenRouter:  https://openrouter.ai/api/v1    (AI_MODEL=deepseek/deepseek-v4-flash)
#   Groq:        https://api.groq.com/openai/v1
#   Local vLLM/Ollama: http://localhost:11434/v1 (modelo propio fine-tuneado)
# NOTA: los IDs legacy "deepseek-chat"/"deepseek-reasoner" se dan de baja el
# 2026-07-24; usar "deepseek-v4-flash" (ver docs del proveedor).
AI_BASE_URL="https://api.deepseek.com"
AI_API_KEY=""
AI_MODEL="deepseek-v4-flash"
# Modelo barato para tareas auxiliares (títulos, extracción de memoria)
AI_SMALL_MODEL="deepseek-v4-flash"
# JSON extra que se mergea (shallow) al body de TODA request de chat/completions.
# Lo necesitan algunos gateways: p. ej. deepseek-v4-flash vía OpenCode Go
# (https://opencode.ai/zen/go/v1) arranca en modo "thinking" y gasta todo
# max_tokens en reasoning_content dejando content vacío; se desactiva así:
# AI_EXTRA_BODY="{\"thinking\":{\"type\":\"disabled\"}}"
# JSON inválido → se loguea un error y se ignora (la app no muere).

# --- Moderación (capa 2 de seguridad) ---
# Clasificador de contenido OpenAI (modelo "omni-moderation-latest", gratis).
# Se usa sobre la entrada del usuario y la salida del LLM. Si no se configura,
# la app funciona igual (fail-open): la capa 1 (regex) sigue siendo el piso de
# seguridad. Ver src/lib/moderation.ts y docs/research-safety.md §3.2.
# OPENAI_API_KEY=""
