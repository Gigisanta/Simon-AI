# --- Base de datos (Postgres / Neon) ---
# Runtime: URL pooled (pgbouncer). Migraciones y seed: URL directa (UNPOOLED).
# En Vercel las provee la integración Neon del Marketplace; en local,
# `vercel env pull` las deja en .env.local (que pisa este archivo).
DATABASE_URL=""
DATABASE_URL_UNPOOLED=""

# --- Auth (better-auth) ---
# Generar con: openssl rand -base64 32
BETTER_AUTH_SECRET=""
# URL pública de la app (origen confiable para better-auth).
BETTER_AUTH_URL="http://localhost:3000"

# --- Email transaccional (verificación del tutor/a + alertas de crisis) ---
# El tutor/a debe verificar su email antes de dar de alta a un menor.
# Si RESEND_API_KEY está seteada, se envía el email con Resend. Si NO está,
# la app loguea el link de verificación por consola (fallback de desarrollo:
# no rompe el registro local). Los menores usan email sintético .invalid y
# NUNCA reciben email. Ver docs/research-guardian.md §3.
# RESEND_API_KEY=""
# EMAIL_FROM="Simón <onboarding@resend.dev>"

# --- Proveedor de IA (intercambiable) ---
# Cualquier endpoint compatible con la API de OpenAI funciona:
#   OpenCode Go: https://opencode.ai/zen/go/v1   (AI_MODEL=deepseek-v4-flash)
#   DeepSeek:    https://api.deepseek.com        (AI_MODEL=deepseek-v4-flash)
#   OpenRouter:  https://openrouter.ai/api/v1    (AI_MODEL=deepseek/deepseek-v4-flash)
#   Local vLLM/Ollama: http://localhost:11434/v1 (modelo propio fine-tuneado)
# NOTA: los IDs legacy "deepseek-chat"/"deepseek-reasoner" se dan de baja el
# 2026-07-24; usar "deepseek-v4-flash" (ver docs del proveedor).
AI_BASE_URL="https://opencode.ai/zen/go/v1"
AI_API_KEY=""
AI_MODEL="deepseek-v4-flash"
# Modelo barato para tareas auxiliares (títulos, extracción de memoria)
AI_SMALL_MODEL="deepseek-v4-flash"
# JSON extra que se mergea (shallow) al body de TODA request de chat/completions.
# Lo necesitan algunos gateways: deepseek-v4-flash vía OpenCode Go arranca en
# modo "thinking" y gasta todo max_tokens en reasoning_content dejando content
# vacío; se desactiva así (OBLIGATORIO con OpenCode Go):
AI_EXTRA_BODY="{\"thinking\":{\"type\":\"disabled\"}}"
# JSON inválido → se loguea un error y se ignora (la app no muere).
# Timeout de generación en ms (default 25000).
# AI_GENERATION_TIMEOUT_MS="25000"

# --- Moderación (capa 2 de seguridad, en cascada) ---
# 1º OpenAI omni-moderation (si hay key válida) → 2º clasificador con el LLM
# principal → si ninguna capa está disponible, la SALIDA se bloquea (fail-closed)
# y la capa 1 (regex) sigue siendo el piso. Ver src/lib/moderation.ts.
# OPENAI_API_KEY=""

# --- Rate limit (opcional, recomendado en producción) ---
# Con ambas seteadas usa Upstash Redis (ventana fija distribuida); sin ellas,
# fallback in-memory por instancia. Ver src/lib/rate-limit.ts.
# También activa el rate limit COMPARTIDO de better-auth (login/registro) vía
# secondaryStorage. Ver src/lib/auth-secondary-storage.ts.
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""
